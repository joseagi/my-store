{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "rootDir": "..",
    "outDir": "../dist/prisma"
  },
  "include": [
    "*.ts",
    "../prisma.config.ts"
  ],
  "exclude": [
    "../node_modules",
    "../src"
  ]
}